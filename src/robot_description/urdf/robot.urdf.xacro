<?xml version="1.0"?>

<robot name="my_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- ########################## -->
    <!--   Geometry and constants   -->
    <!-- ########################## -->

    <!-- Pi -->
    <xacro:property name="pi_const" value="3.14159265" />

    <!-- Body Dimensions -->
    <xacro:property name="a" value="0.0969" />  
    <xacro:property name="b" value="0.065" />
    <xacro:property name="c" value="0.147" />
    <xacro:property name="baseframe_offset_y" value="-0.02575" />

    <!-- Wheel and caster radius -->
    <xacro:property name="r" value="0.0355" />

    <!-- Wheel width -->
    <xacro:property name="d" value="0.01" />

    <!-- Wheel Offset to chassis in Y axis -->
    <xacro:property name="wheel_offset_x" value="-0.00925" />
    <xacro:property name="wheel_offset_y" value="0.01" />

    <!-- AprilTag properties -->
    <xacro:property name="tag_size" value="0.094" />
    <xacro:property name="tag_thickness" value="0.001" />
    <xacro:property name="tag_mass" value="0.01" />
    <xacro:property name="tag_offset_y" value="0.0" />

    <!-- Weapon properties -->
    <xacro:property name="weapon_length" value="0.060" />   
    <xacro:property name="weapon_width" value="0.124" />  
    <xacro:property name="weapon_height" value="0.010" />  
    <xacro:property name="weapon_offset_x" value="0.08495" />
    <xacro:property name="weapon_mass" value="0.1" />       <!-- Mass of weapon (kg) -->
    <xacro:property name="weapon_density" value="1430.0" /> <!-- Material density -->

    <xacro:property name="s1" value="${r}" />
    <xacro:property name="s2" value="${wheel_offset_x}" />
    <xacro:property name="s4" value="${c/2.0+wheel_offset_y}" />

    <!-- Upright support box dimensions (independently definable) -->
    <xacro:property name="support_width" value="0.0515" />      <!-- Width in X direction -->
    <xacro:property name="support_depth" value="0.008" />     <!-- Depth in Y direction -->
    <xacro:property name="support_height" value="0.065" />    <!-- Height in Z direction -->
    
    <!-- Caster ball properties -->
    <xacro:property name="caster_radius" value="${support_depth/2}" />    <!-- Radius of the ball casters -->
    <xacro:property name="caster_mass" value="0.005" />      <!-- Mass of each caster ball -->
    <xacro:property name="caster_offset" value="${support_height/2}" /> <!-- Position offset from box center -->

    <!-- ########################## -->
    <!--      Mass and inertia      -->
    <!-- ########################## -->

    <!-- Material Density -->
    <xacro:property name="d1" value="1430.0" />
    <xacro:property name="d2" value="1430.0" />
    <xacro:property name="d3" value="1430.0" />
    <xacro:property name="d4" value="1430.0" />  <!-- Density for caster balls -->
    <xacro:property name="d5" value="${weapon_density}" /> <!-- Density for weapon -->

    <!-- Mass -->
    <xacro:property name="m1" value="${d1*a*b*c}" />
    <xacro:property name="m2" value="${d2*pi_const*r*r*d}" />
    <xacro:property name="m3" value="${d3*support_width*support_depth*support_height}" />
    <xacro:property name="m4" value="${d4 * (4.0/3.0) * pi_const * caster_radius * caster_radius * caster_radius}" /> <!-- Mass of caster ball -->
    <xacro:property name="m5" value="${d5*weapon_length*weapon_width*weapon_height}" /> <!-- Mass of weapon -->

    <!-- Inertia -->
    <xacro:property name="Ix_body" value="${(1.0/12.0)*m1*(b*b+c*c)}" />
    <xacro:property name="Iy_body" value="${(1.0/12.0)*m1*(a*a+b*b)}" />
    <xacro:property name="Iz_body" value="${(1.0/12.0)*m1*(a*a+c*c)}" />
    <xacro:property name="Iz_wheel" value="${0.5*m2*r*r}" />
    <xacro:property name="I_wheel" value="${(1.0/12.0)*m2*(3.0*r*r+d*d)}" />
    
    <!-- Inertia for box support -->
    <xacro:property name="I_support_x" value="${(1.0/12.0)*m3*(support_depth*support_depth + support_height*support_height)}" />
    <xacro:property name="I_support_y" value="${(1.0/12.0)*m3*(support_width*support_width + support_height*support_height)}" />
    <xacro:property name="I_support_z" value="${(1.0/12.0)*m3*(support_width*support_width + support_depth*support_depth)}" />
    
    <!-- Inertia for caster ball (solid sphere) -->
    <xacro:property name="I_caster" value="${(2.0/5.0)*m4*caster_radius*caster_radius}" />
    
    <!-- Inertia for weapon (rectangular box) -->
    <xacro:property name="Ix_weapon" value="${(1.0/12.0)*m5*(weapon_width*weapon_width + weapon_height*weapon_height)}" />
    <xacro:property name="Iy_weapon" value="${(1.0/12.0)*m5*(weapon_length*weapon_length + weapon_height*weapon_height)}" />
    <xacro:property name="Iz_weapon" value="${(1.0/12.0)*m5*(weapon_length*weapon_length + weapon_width*weapon_width)}" />

    <!-- Complete inertia macros -->
    <xacro:macro name="inertia_body">
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 ${s1}"/>
            <mass value="${m1}"/>
            <inertia ixx="${Ix_body}" ixy="0.0" ixz="0.0" iyy="${Iy_body}" iyz="0.0" izz="${Iz_body}" />
        </inertial>
    </xacro:macro>

    <xacro:macro name="inertia_wheel">
        <inertial>
            <origin rpy="${pi_const/2.0} 0 0" xyz="0 0 0"/>
            <mass value="${m2}"/>
            <inertia ixx="${I_wheel}" ixy="0.0" ixz="0.0" iyy="${I_wheel}" iyz="0.0" izz="${Iz_wheel}" />
        </inertial>
    </xacro:macro>

    <xacro:macro name="inertia_support">
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="${m3}"/>
            <inertia ixx="${I_support_x}" ixy="0.0" ixz="0.0" iyy="${I_support_y}" iyz="0.0" izz="${I_support_z}" />
        </inertial>
    </xacro:macro>

    <xacro:macro name="inertia_caster">
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="${m4}"/>
            <inertia ixx="${I_caster}" ixy="0.0" ixz="0.0" iyy="${I_caster}" iyz="0.0" izz="${I_caster}" />
        </inertial>
    </xacro:macro>

    <xacro:macro name="inertia_weapon">
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="${m5}"/>
            <inertia ixx="${Ix_weapon}" ixy="0.0" ixz="0.0" iyy="${Iy_weapon}" iyz="0.0" izz="${Iz_weapon}" />
        </inertial>
    </xacro:macro>

    <xacro:macro name="inertia_tag">
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="${tag_mass}"/>
            <inertia ixx="${(1.0/12.0)*tag_mass*(tag_size*tag_size + tag_thickness*tag_thickness)}" 
                     ixy="0.0" ixz="0.0" 
                     iyy="${(1.0/12.0)*tag_mass*(tag_size*tag_size + tag_thickness*tag_thickness)}" 
                     iyz="0.0" 
                     izz="${(1.0/12.0)*tag_mass*(tag_size*tag_size + tag_size*tag_size)}" />
        </inertial>
    </xacro:macro>

    <!-- Include gazebo file -->
    <xacro:include filename="$(find robot_description)/urdf/gazebo/robot.gazebo.xacro" />

    <!-- Links and joints -->
    <link name="base_footprint"> </link>
    <joint name="body_link_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="body_link"/>
        <origin xyz="${baseframe_offset_y} 0 0" rpy="0 0 0"/>
    </joint>

    <link name="body_link">
        <visual>
            <geometry><box size="${a} ${c} ${b}" /></geometry>
            <origin rpy="0 0 0" xyz="0 0 ${s1}"/>
            <material name="White"><color rgba="1 1 1 1"/></material>
        </visual>
        <collision>
            <geometry><box size="${a} ${c} ${b}" /></geometry>
            <origin rpy="0 0 0" xyz="0 0 ${s1}"/>
        </collision>
        <xacro:inertia_body/>
    </link>

    <!-- Weapon Link -->
    <joint name="weapon_joint" type="fixed">
        <parent link="body_link"/>
        <child link="weapon_link"/>
        <origin xyz="${weapon_offset_x} 0 ${s1}" rpy="0 0 0"/>
    </joint>
    <link name="weapon_link">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry><box size="${weapon_length} ${weapon_width} ${weapon_height}"/></geometry>
            <material name="Red"><color rgba="1 0 0 1"/></material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry><box size="${weapon_length} ${weapon_width} ${weapon_height}"/></geometry>
        </collision>
        <xacro:inertia_weapon/>
    </link>

    <!-- Top AprilTag -->
    <joint name="top_tag_joint" type="fixed">
        <parent link="body_link"/>
        <child link="top_apriltag_link"/>
        <origin xyz="${tag_offset_y} 0 ${s1 + b/2 + tag_thickness/2}" rpy="0 0 0"/>
    </joint>
    <link name="top_apriltag_link">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry><box size="${tag_size} ${tag_size} ${tag_thickness}"/></geometry>
            <material name="White"><color rgba="1 1 1 1"/></material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry><box size="${tag_size} ${tag_size} ${tag_thickness}"/></geometry>
        </collision>
        <xacro:inertia_tag/>
    </link>

    <!-- Top AprilTag Optical Frame -->
    <joint name="top_tag_optical_joint" type="fixed">
        <parent link="top_apriltag_link"/>
        <child link="top_apriltag_optical"/>
        <origin xyz="0 0 0" rpy="0 ${pi_const} ${pi_const/2}"/>
    </joint>
    <link name="top_apriltag_optical"/>

    <!-- Bottom AprilTag -->
    <joint name="bottom_tag_joint" type="fixed">
        <parent link="body_link"/>
        <child link="bottom_apriltag_link"/>
        <origin xyz="${tag_offset_y} 0 ${s1 - b/2 - tag_thickness/2}" rpy="${pi_const} 0 0"/>
    </joint>
    <link name="bottom_apriltag_link">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry><box size="${tag_size} ${tag_size} ${tag_thickness}"/></geometry>
            <material name="White"><color rgba="1 1 1 1"/></material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry><box size="${tag_size} ${tag_size} ${tag_thickness}"/></geometry>
        </collision>
        <xacro:inertia_tag/>
    </link>

    <!-- Bottom AprilTag Optical Frame -->
    <joint name="bottom_tag_optical_joint" type="fixed">
        <parent link="bottom_apriltag_link"/>
        <child link="bottom_apriltag_optical"/>
        <origin xyz="0 0 0" rpy="0 0 ${pi_const/2}"/>
    </joint>
    <link name="bottom_apriltag_optical"/>

    <!-- Wheels -->
    <joint name="right_wheel_joint" type="continuous">
        <parent link="body_link"/>
        <child link="right_wheel_link"/>
        <origin xyz="${s2} ${-s4} ${r}" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit effort="50000" velocity="10"/>
        <dynamics damping="1.0" friction="1.0"/>
    </joint>
    <link name="right_wheel_link">
        <visual>
            <origin rpy="${pi_const/2} 0 0" xyz="0 0 0"/>
            <geometry><cylinder length="${d}" radius="${r}"/></geometry>
            <material name="White"><color rgba="1 1 1 1"/></material>
        </visual>
        <collision>
            <origin rpy="${pi_const/2} 0 0" xyz="0 0 0"/>
            <geometry><cylinder length="${d}" radius="${r}"/></geometry>
        </collision>
        <xacro:inertia_wheel/>
    </link>

    <joint name="left_wheel_joint" type="continuous">
        <parent link="body_link"/>
        <child link="left_wheel_link"/>
        <origin xyz="${s2} ${s4} ${r}" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit effort="50000" velocity="10"/>
        <dynamics damping="1.0" friction="1.0"/>
    </joint>
    <link name="left_wheel_link">
        <visual>
            <origin rpy="${pi_const/2} 0 0" xyz="0 0 0"/>
            <geometry><cylinder length="${d}" radius="${r}"/></geometry>
            <material name="White"><color rgba="1 1 1 1"/></material>
        </visual>
        <collision>
            <origin rpy="${pi_const/2} 0 0" xyz="0 0 0"/>
            <geometry><cylinder length="${d}" radius="${r}"/></geometry>
        </collision>
        <xacro:inertia_wheel/>
    </link>

    <!-- Two upright boxes with independently definable top/bottom casters -->
    <xacro:macro name="upright_with_casters" params="name y_offset">
        <!-- Upright box -->
        <joint name="${name}_joint" type="fixed">
            <parent link="body_link"/>
            <child link="${name}_link"/>
            <origin xyz="${a/2 + support_width/2} ${y_offset} ${r}" rpy="0 0 0"/>
        </joint>
        <link name="${name}_link">
            <visual>
                <origin rpy="0 0 0"/>
                <geometry><box size="${support_width} ${support_depth} ${support_height}"/></geometry>
                <material name="White"><color rgba="1 1 1 1"/></material>
            </visual>
            <collision>
                <origin rpy="0 0 0"/>
                <geometry><box size="${support_width} ${support_depth} ${support_height}"/></geometry>
            </collision>
            <xacro:inertia_support/>
        </link>

        <!-- Top caster ball -->
        <joint name="${name}_top_caster_joint" type="fixed">
            <parent link="${name}_link"/>
            <child link="${name}_top_caster_link"/>
            <origin xyz="${support_width/2-caster_radius} 0 ${caster_offset}" rpy="0 0 0"/>
        </joint>
        <link name="${name}_top_caster_link">
            <visual>
                <origin rpy="0 0 0"/>
                <geometry><sphere radius="${caster_radius}"/></geometry>
                <material name="White"><color rgba="1 1 1 1"/></material>
            </visual>
            <collision>
                <origin rpy="0 0 0"/>
                <geometry><sphere radius="${caster_radius}"/></geometry>
            </collision>
            <xacro:inertia_caster/>
        </link>

        <!-- Bottom caster ball -->
        <joint name="${name}_bottom_caster_joint" type="fixed">
            <parent link="${name}_link"/>
            <child link="${name}_bottom_caster_link"/>
            <origin xyz="${support_width/2-caster_radius} 0 ${-caster_offset}" rpy="0 0 0"/>
        </joint>
        <link name="${name}_bottom_caster_link">
            <visual>
                <origin rpy="0 0 0"/>
                <geometry><sphere radius="${caster_radius}"/></geometry>
                <material name="White"><color rgba="1 1 1 1"/></material>
            </visual>
            <collision>
                <origin rpy="0 0 0"/>
                <geometry><sphere radius="${caster_radius}"/></geometry>
            </collision>
            <xacro:inertia_caster/>
        </link>
    </xacro:macro>

    <xacro:upright_with_casters name="front_left_support" y_offset="${c/2 - support_depth/2}"/>
    <xacro:upright_with_casters name="front_right_support" y_offset="${-c/2 + support_depth/2}"/>

</robot>